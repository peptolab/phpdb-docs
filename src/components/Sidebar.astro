---
/**
 * Override of Starlight's built-in Sidebar.
 *
 * Exists solely so we can substitute our local `SidebarSublist.astro` —
 * the upstream `SidebarSublist` is not in Starlight's component-override
 * schema, so the only way to replace it is to fork its parent and have
 * the fork import our copy directly.
 */
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from './SidebarSublist.astro';

const { sidebar } = Astro.locals.starlightRoute;
---

<SidebarPersister>
    <SidebarSublist sublist={sidebar} />
</SidebarPersister>

<div class="md:sl-hidden">
    <MobileMenuFooter />
</div>
